# Required
EMAIL_RECIPIENT=your-email@example.com

# AI Provider (choose one)
# Gemini (recommended, free tier available)
GEMINI_API_KEY=your_gemini_key_here
# Kimi (alternative)
# KIMI_API_KEY=your_kimi_key_here

# Email Delivery (choose one)
# SendGrid (recommended)
SENDGRID_API_KEY=your_sendgrid_key_here
# AWS SES (alternative - not yet implemented)
# SES credentials would go here
# Gmail (alternative - not yet implemented)
# Gmail credentials would go here

# Optional: Data Sources
# Comma-separated list of URLs to scrape
SOURCES=https://www.firsttracts.com/real-estate/our-listings

# Optional: Filtering Criteria
# ALLOWED_PROPERTIES=Allegheny Springs,Rimfire Lodge
# REQUIRED_LOCATION_KEYWORDS=Snowshoe Village,Snowshoe
# MIN_BEDROOMS=1
# MAX_BEDROOMS=1
# MIN_PRICE=150000
# MAX_PRICE=200000

# Optional: Pagination
# MAX_PAGES_PER_SOURCE=10

# Optional: AI Settings
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash

# Optional: Email Settings
# EMAIL_FROM=snowshoe-bot@example.com
# SMTP_PROVIDER=sendgrid

# Optional: Execution Mode
# DRY_RUN=true              # Set to true to skip sending email
# SKIP_AI=false             # Set to true to skip AI enrichment (faster)

# Optional: Persistence & Scheduling
# DATA_PATH=./data/properties.json
# RUN_FREQUENCY=0 8 * * *

# Optional: Logging
# LOG_LEVEL=INFO
